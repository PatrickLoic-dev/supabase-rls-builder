    "clsx": "^2.1.1",
    "commander": "^15.0.0",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "openai": "^6.42.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
